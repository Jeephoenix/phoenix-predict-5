# ─── Deployer ─────────────────────────────────────────────────────────────────
# Private key of the deployer wallet (no 0x prefix needed by some tools)
PRIVATE_KEY=your_private_key_here

# ─── RPC Endpoints ────────────────────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── Basescan Verification ────────────────────────────────────────────────────
BASESCAN_API_KEY=your_basescan_api_key_here

# ─── Contract Config ──────────────────────────────────────────────────────────
# Address that receives protocol fees (defaults to deployer if not set)
FEE_RECIPIENT=0xYourFeeRecipientAddress

# Contract owner address (defaults to deployer if not set)
OWNER_ADDRESS=0xYourOwnerAddress

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourDeployedContractAddress
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org

# ─── Optional ─────────────────────────────────────────────────────────────────
# CoinMarketCap API key for gas reporter USD estimates
CMC_API_KEY=your_cmc_api_key_here
REPORT_GAS=false
